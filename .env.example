# Supabase 接続設定
# Supabase プロジェクトの Settings > API から取得
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# アプリのベースURL（QRコード・Magic Link に使用）
# ============================================================
# ⚠️ この値を間違えると QRコードが localhost を指し、本番で使えません。
#
# ローカル開発:
#   VITE_APP_URL=http://localhost:5173
#
# Vercel 本番:
#   VITE_APP_URL=https://goennet-app.vercel.app
#   ※ .env ではなく Vercel ダッシュボード > Settings > Environment Variables に設定すること
#   ※ .env.production はローカルの本番ビルド確認用（git には含めない）
#
# QRコードURL生成: src/lib/authConfig.js の APP_URL を経由
# Magic Link リダイレクト: src/lib/authConfig.js の AUTH_REDIRECT_URL を経由
VITE_APP_URL=http://localhost:5173

# ============================================================
# テストログイン表示フラグ
# ============================================================
# true  → テストログインボタンを表示・Magic Link フォームを非表示
# false → Magic Link フォームを表示（通常の本番動作）
#
# ローカル開発中: true に設定（email rate limit 回避）
# Vercel 本番テスト中: Vercel ダッシュボードで true に設定して Redeploy
# 本番リリース後: false に設定（または変数ごと削除）して Redeploy
VITE_ENABLE_TEST_LOGIN=false

# 注意: service_role key は絶対にここに書かない
# service_role key はサーバーサイド (Edge Functions) のみで使用すること
